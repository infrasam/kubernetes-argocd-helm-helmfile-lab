{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Falco metrics datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.2.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "row", "name": "Row", "version": "" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Falco Runtime Security Monitoring - Prometheus metrics (falcosecurity_*)",
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "expr": "sum(increase(falcosecurity_falco_rules_matches_total{priority=~\"$priority\",rule_name=~\"$searchpattern\"}[$__range]))",
          "legendFormat": "Total",
          "refId": "A"
        }
      ],
      "title": "Total Events",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "mappings": [], "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 9, "w": 6, "x": 4, "y": 1 },
      "id": 2,
      "options": {
        "displayLabels": [],
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "values": ["value"] },
        "pieType": "pie",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "expr": "sum by (source) (increase(falcosecurity_falco_rules_matches_total{priority=~\"$priority\",rule_name=~\"$searchpattern\"}[$__range]))",
          "legendFormat": "{{source}}",
          "refId": "A"
        }
      ],
      "title": "Sources",
      "type": "piechart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "mappings": [], "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 9, "w": 6, "x": 10, "y": 1 },
      "id": 3,
      "options": {
        "displayLabels": [],
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "values": ["value"] },
        "pieType": "pie",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "expr": "sum by (priority) (increase(falcosecurity_falco_rules_matches_total{priority=~\"$priority\",rule_name=~\"$searchpattern\"}[$__range]))",
          "legendFormat": "{{priority}}",
          "refId": "A"
        }
      ],
      "title": "Priorities",
      "type": "piechart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "mappings": [], "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 1 },
      "id": 4,
      "options": {
        "displayLabels": [],
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "values": ["value"] },
        "pieType": "pie",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "expr": "topk($top, sum by (rule_name) (increase(falcosecurity_falco_rules_matches_total{priority=~\"$priority\",rule_name=~\"$searchpattern\"}[$__range])))",
          "legendFormat": "{{rule_name}}",
          "refId": "A"
        }
      ],
      "title": "Rules (Top $top)",
      "type": "piechart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 35,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "normal" }
          },
          "mappings": [],
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 12, "w": 12, "x": 0, "y": 10 },
      "id": 5,
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "mean", "min", "max"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "expr": "sum by (priority) (rate(falcosecurity_falco_rules_matches_total{priority=~\"$priority\",rule_name=~\"$searchpattern\"}[1m]))",
          "legendFormat": "{{priority}}",
          "refId": "A"
        }
      ],
      "title": "Events rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" } },
          "mappings": [],
          "noValue": "No Rule Violations from Pods",
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Rule Violations" },
            "properties": [{ "id": "custom.width", "value": 140 }]
          }
        ]
      },
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 10 },
      "id": 6,
      "options": {
        "cellHeight": "sm",
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Rule Violations" }]
      },
      "targets": [
        {
          "expr": "topk($top, sum by (namespace, pod) (increase(falcosecurity_falco_rules_matches_total{priority=~\"$priority\",rule_name=~\"$searchpattern\"}[$__range])))",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "container": true,
              "endpoint": true,
              "instance": true,
              "job": true,
              "service": true
            },
            "indexByName": { "namespace": 0, "pod": 1, "Value": 2 },
            "renameByName": { "namespace": "Namespace", "pod": "Pod", "Value": "Rule Violations" }
          }
        }
      ],
      "title": "Top $top Pods",
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" } }, "mappings": [], "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 22 },
      "id": 7,
      "options": {
        "cellHeight": "sm",
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Hits" }]
      },
      "targets": [
        {
          "expr": "topk($top, sum by (rule_name, priority, source) (increase(falcosecurity_falco_rules_matches_total{priority=~\"$priority\",rule_name=~\"$searchpattern\"}[$__range])))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "container": true,
              "endpoint": true,
              "instance": true,
              "job": true,
              "namespace": true,
              "pod": true,
              "service": true
            },
            "indexByName": { "rule_name": 0, "priority": 1, "source": 2, "Value": 3 },
            "renameByName": { "rule_name": "Rule", "priority": "Priority", "source": "Source", "Value": "Hits" }
          }
        }
      ],
      "title": "Top $top Rules",
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["falco", "security", "runtime"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "allValue": ".*",
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] },
        "definition": "label_values(falcosecurity_falco_rules_matches_total, priority)",
        "hide": 0,
        "includeAll": true,
        "label": "Priority",
        "multi": true,
        "name": "priority",
        "options": [],
        "query": {
          "qryType": 1,
          "query": "label_values(falcosecurity_falco_rules_matches_total, priority)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": true, "text": "20", "value": "20" },
        "hide": 0,
        "includeAll": false,
        "label": "Top",
        "multi": false,
        "name": "top",
        "options": [
          { "selected": false, "text": "5", "value": "5" },
          { "selected": false, "text": "10", "value": "10" },
          { "selected": true, "text": "20", "value": "20" },
          { "selected": false, "text": "50", "value": "50" }
        ],
        "query": "5,10,20,50",
        "type": "custom"
      },
      {
        "current": { "selected": true, "text": ".*", "value": ".*" },
        "hide": 0,
        "includeAll": false,
        "label": "Search-Pattern (regex on rule_name)",
        "name": "searchpattern",
        "options": [{ "selected": true, "text": ".*", "value": ".*" }],
        "query": ".*",
        "skipUrlSync": false,
        "type": "textbox"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "browser",
  "title": "Falco Runtime Security (Prometheus)",
  "uid": "falco-runtime-security-prom",
  "version": 2,
  "weekStart": ""
}