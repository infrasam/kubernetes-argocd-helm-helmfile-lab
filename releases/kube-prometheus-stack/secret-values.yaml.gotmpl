---
externalSecrets:
  grafana-admin:
    refreshInterval: "1h"
    clusterSecretStoreName: css-{{ .Values.cluster }}
    target:
      creationPolicy: Owner
      deletionPolicy: Delete
    data:
      - secretKey: admin-user
        remoteRef:
          key: kube-prometheus-stack/grafana-admin
          property: admin-user
      - secretKey: admin-password
        remoteRef:
          key: kube-prometheus-stack/grafana-admin
          property: admin-password
