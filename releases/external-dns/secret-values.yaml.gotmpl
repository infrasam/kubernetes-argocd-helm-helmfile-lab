externalSecrets:
  external-dns-cloudflare:
    refreshInterval: "1h"
    clusterSecretStoreName: css-{{ .Values.cluster }}
    target:
      creationPolicy: Owner
      deletionPolicy: Delete
    data:
      - secretKey: cloudflare-api-token
        remoteRef:
          key: external-dns/cloudflare
          property: cloudflare-api-token
